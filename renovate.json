{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitMessageAction": "update",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "enabledManagers": [
    "github-actions",
    "nuget",
    "dockerfile",
    "docker-compose",
    "mise",
    "custom.regex"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/(^|/)Dockerfile(\\..+)?$/"
    ]
  },
  "docker-compose": {
    "managerFilePatterns": [
      "/(^|/)docker-compose[^/]*\\.ya?ml$/",
      "/^compose/[^/]+\\.ya?ml$/"
    ]
  },
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group TUnit test dependencies",
      "groupName": "TUnit",
      "matchPackageNames": [
        "/^TUnit/"
      ]
    },
    {
      "description": "Group Dapr SDK dependencies",
      "groupName": "Dapr SDK",
      "matchPackageNames": [
        "/^Dapr/"
      ]
    },
    {
      "description": "Group Docker Compose images",
      "matchManagers": [
        "docker-compose"
      ],
      "groupName": "Docker images"
    },
    {
      "description": "Group Makefile tool versions into one PR",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Makefile tool versions"
    },
    {
      "description": "Group mise-managed tools (node, dapr CLI, act) into one PR",
      "matchManagers": [
        "mise"
      ],
      "groupName": "mise tools"
    },
    {
      "description": "Group Dapr runtime container images (daprd, placement, dapr)",
      "matchPackageNames": [
        "daprio/daprd",
        "daprio/dapr",
        "daprio/placement"
      ],
      "groupName": "Dapr runtime images"
    },
    {
      "description": "Group .NET base images (sdk, aspnet)",
      "matchPackageNames": [
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/aspnet"
      ],
      "groupName": ".NET base images"
    },
    {
      "description": "Group Jaeger images",
      "matchPackageNames": [
        "jaegertracing/jaeger",
        "jaegertracing/all-in-one"
      ],
      "groupName": "Jaeger"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Makefile tool versions via inline renovate comments",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)(?: registryUrl=(?<registryUrl>[^\\s]+))?(?: versioning=(?<versioning>[^\\s]+))?(?: extractVersion=(?<extractVersion>[^\\s]+))?\\n[A-Z_]+\\s*[?:]?=\\s*(?<currentValue>[^\\s]+)"
      ]
    }
  ]
}
