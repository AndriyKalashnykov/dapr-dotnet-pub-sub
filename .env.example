# SPDX-License-Identifier: MIT
# Committed source of truth for operator-tunable values. Copy to `.env` (gitignored)
# to override per-developer. `${VAR:-default}` form so an inherited env / `make VAR=…`
# override WINS over the sourced default (avoids the clobber trap where a sourced
# plain `KEY=value` overrides a caller's export).
#
# Docker Compose reads its defaults from the inline `${VAR:-default}` forms in
# compose/docker-compose.yml; this file documents them and is sourced by the e2e
# shell harnesses (scripts/e2e-compose.sh).

# --- Host-side published ports (the collision axis for parallel runs) ---
PRODUCER_HOST_PORT="${PRODUCER_HOST_PORT:-5232}"
CONSUMER_HOST_PORT="${CONSUMER_HOST_PORT:-5231}"
JAEGER_HOST_PORT="${JAEGER_HOST_PORT:-16686}"

# --- Container-internal app ports (must equal the app's listen port + daprd --app-port) ---
PRODUCER_APP_PORT="${PRODUCER_APP_PORT:-5232}"
CONSUMER_APP_PORT="${CONSUMER_APP_PORT:-5231}"

# --- Dapr sidecar HTTP ports ---
PRODUCER_DAPR_HTTP_PORT="${PRODUCER_DAPR_HTTP_PORT:-3532}"
CONSUMER_DAPR_HTTP_PORT="${CONSUMER_DAPR_HTTP_PORT:-3531}"

# --- Dapr placement service port (shared by placement + both sidecars) ---
PLACEMENT_PORT="${PLACEMENT_PORT:-50006}"

# --- e2e harness tunables ---
PROPAGATION_TIMEOUT="${PROPAGATION_TIMEOUT:-60}"
CURL_MAX_TIME="${CURL_MAX_TIME:-5}"
POLL_INTERVAL="${POLL_INTERVAL:-1}"

# --- OTel / Jaeger trace assertion ---
# Dapr exports spans with service.name == the daprd app-id.
JAEGER_QUERY_PORT="${JAEGER_QUERY_PORT:-16686}"
JAEGER_POLL_SECONDS="${JAEGER_POLL_SECONDS:-45}"
OTEL_PRODUCER_SERVICE="${OTEL_PRODUCER_SERVICE:-producer}"
OTEL_CONSUMER_SERVICE="${OTEL_CONSUMER_SERVICE:-consumer}"
